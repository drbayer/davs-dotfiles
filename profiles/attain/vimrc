let g:tagbar_type_tf = {
  \ 'ctagstype': 'tf',
  \ 'kinds': [
    \ 'r:Resource',
    \ 'R:Resource',
    \ 'd:Data',
    \ 'D:Data',
    \ 'v:Variable',
    \ 'V:Variable',
    \ 'p:Provider',
    \ 'P:Provider',
    \ 'm:Module',
    \ 'M:Module',
    \ 'o:Output',
    \ 'O:Output',
    \ 'f:TFVar',
    \ 'F:TFVar'
  \ ]
\ }

if has('nvim')
lua << EOF
    require("claudecode").setup({
        auto_start = false
    })
    require("snacks").setup({
        picker = { enabled = true }
    })

    -- Re-apply custom highlights whenever colorscheme changes
    local function apply_custom_highlights()
        -- Terminal windows: define a group and apply via winhighlight in TermOpen
        vim.api.nvim_set_hl(0, "TermNormal",                    { bg = "#000000" })
        -- Snacks picker windows
        vim.api.nvim_set_hl(0, "SnacksPickerNormal",            { bg = "#000000" })
        vim.api.nvim_set_hl(0, "SnacksPickerPreviewNormal",     { bg = "#000000" })
        vim.api.nvim_set_hl(0, "SnacksPickerInputNormal",       { bg = "#000000" })
        vim.api.nvim_set_hl(0, "SnacksPickerBorder",            { bg = "#000000" })
        vim.api.nvim_set_hl(0, "SnacksPickerPreviewBorder",     { bg = "#000000" })
        vim.api.nvim_set_hl(0, "SnacksPickerInputBorder",       { bg = "#000000" })
    end

    vim.api.nvim_create_autocmd("ColorScheme", {
        pattern = "*",
        callback = apply_custom_highlights,
    })

    -- Apply bg override to terminal windows via winhighlight
    vim.api.nvim_create_autocmd("TermOpen", {
        callback = function()
            vim.opt_local.winhighlight = "Normal:TermNormal"
        end,
    })

    -- Apply bg override to snacks picker windows via winhighlight
    vim.api.nvim_create_autocmd("FileType", {
        pattern = { "snacks_picker_list", "snacks_picker_input" },
        callback = function()
            vim.opt_local.winhighlight = "Normal:SnacksPickerNormal,NormalFloat:SnacksPickerNormal,FloatBorder:SnacksPickerBorder"
        end,
    })
    vim.api.nvim_create_autocmd("FileType", {
        pattern = "snacks_picker_preview",
        callback = function()
            vim.opt_local.winhighlight = "Normal:SnacksPickerPreviewNormal,NormalFloat:SnacksPickerPreviewNormal,FloatBorder:SnacksPickerPreviewBorder"
        end,
    })

    -- Apply colorscheme after all plugins (including snacks) have initialized
    vim.api.nvim_create_autocmd("UIEnter", {
        once = true,
        callback = function()
            vim.cmd("colorscheme torte")
        end,
    })

    -- File/search keybindings via snacks picker
    vim.keymap.set("n", "<leader>ff", function() Snacks.picker.files() end,        { desc = "Find files" })
    vim.keymap.set("n", "<leader>fg", function() Snacks.picker.grep() end,         { desc = "Live grep" })
    vim.keymap.set("n", "<leader>fw", function() Snacks.picker.grep_word() end,    { desc = "Grep word under cursor" })
    vim.keymap.set("n", "<leader>fb", function() Snacks.picker.buffers() end,      { desc = "Find buffers" })
    vim.keymap.set("n", "<leader>fr", function() Snacks.picker.recent() end,       { desc = "Recent files" })
    vim.keymap.set("n", "<leader>fh", function() Snacks.picker.help() end,         { desc = "Search help tags" })
    vim.keymap.set("n", "<leader>gf", function() Snacks.picker.git_files() end,    { desc = "Find git files" })
    vim.keymap.set("n", "<leader>gc", function() Snacks.picker.git_log() end,      { desc = "Git log" })
EOF

endif
